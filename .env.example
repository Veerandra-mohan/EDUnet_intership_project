# DeepInspection AI Environment Variables
# Copy this file to .env and fill in the values for production deployment

# Backend API URL (Frontend needs to know where the backend is hosted)
# Local development:
VITE_API_BASE_URL=http://localhost:8000
# Production:
# VITE_API_BASE_URL=https://your-render-backend-url.onrender.com

# Backend Configuration (Optional configurations for advanced setups)
# ENVIRONMENT=development
# MAX_VIDEO_UPLOAD_MB=20
